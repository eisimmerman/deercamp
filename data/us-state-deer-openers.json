I’m checking the camp file logic for the archive cap so I can give you the exact fix instead of guessing.

I found the regression: the archive grid styling stayed at 5 columns, but the render logic lost the 10-card page slice, so it’s dumping the full archive again.

Thought for 56s
Yep — the grid CSS is still set for 5 columns, but the cap that keeps the archive to 10 cards per page is what got lost. The working paged version uses const archivePageSize = 10; and renders from pagedArchiveEntries, not the full filtered array. 

 

 


In camp.html, inside your CampFeed script, make sure this line exists:

const archivePageSize = 10;
Then replace your current renderArchiveFeed() body with this version:

const renderArchiveFeed = () => {
  const searchTerm = String(searchInput.value || "").trim().toLowerCase();
  const sortMode = sortSelect.value || "newest";

  const archivePool = allFeedEntries.slice(3);

  filteredEntries = archivePool
    .filter(entry => {
      if (!searchTerm) return true;
      return entry.searchBlob.includes(searchTerm);
    })
    .filter(entry => {
      if (activeFilter === "all") return true;
      if (["photo", "audio", "video"].includes(activeFilter)) {
        return entry.mediaType === activeFilter;
      }
      return entry.category === activeFilter;
    })
    .sort((a, b) =>
      sortMode === "oldest"
        ? a.createdAtMs - b.createdAtMs
        : b.createdAtMs - a.createdAtMs
    );

  const totalArchivePosts = filteredEntries.length;
  const maxPageIndex = Math.max(0, Math.ceil(totalArchivePosts / archivePageSize) - 1);
  archivePageIndex = Math.min(archivePageIndex, maxPageIndex);

  const pageStart = archivePageIndex * archivePageSize;
  const pagedArchiveEntries = filteredEntries.slice(pageStart, pageStart + archivePageSize);
  const pageFirst = totalArchivePosts ? pageStart + 4 : 0;
  const pageLast = totalArchivePosts ? pageStart + 3 + pagedArchiveEntries.length : 0;

  resultsCount.textContent = totalArchivePosts
    ? `Archive showing ${formatFeedCount(pageFirst)}–${formatFeedCount(pageLast)} of ${formatFeedCount(totalArchivePosts)} older post${totalArchivePosts === 1 ? "" : "s"}`
    : "No archived posts";

  if (archivePageLabel) {
    archivePageLabel.textContent = totalArchivePosts
      ? `Archive page ${archivePageIndex + 1} of ${maxPageIndex + 1}`
      : "Archive page 0 of 0";
  }

  if (archivePrevBtn) archivePrevBtn.disabled = archivePageIndex <= 0;
  if (archiveNextBtn) archiveNextBtn.disabled = archivePageIndex >= maxPageIndex || !totalArchivePosts;

  archiveList.innerHTML = "";

  if (!pagedArchiveEntries.length) {
    const empty = document.createElement("div");
    empty.className = "feed-empty-state";
    empty.innerHTML = totalArchivePosts
      ? `<strong>No posts on this archive page.</strong><p>Use Previous 10 to go back through older CampFeed posts.</p>`
      : `
        <strong>No posts matched your search.</strong>
        <p>Try another keyword or clear filters to browse the full CampFeed archive.</p>
      `;
    archiveList.appendChild(empty);
    return;
  }

  pagedArchiveEntries.forEach(entry => {
    const card = document.createElement("article");
    card.className = "feed-archive-card";

    const media = document.createElement("div");
    media.className = "feed-archive-media";
    if (entry.imageFit === "contain") media.classList.add("is-contain");

    if (entry.image) {
      const image = document.createElement("img");
      image.src = entry.image;
      image.alt = entry.title || "Feed image";
      image.loading = "lazy";
      media.appendChild(image);
    } else {
      media.innerHTML = `<div class="feed-empty-state" style="height:100%;display:flex;align-items:center;justify-content:center;">No image for this post yet.</div>`;
    }

    const copy = document.createElement("div");
    copy.className = "feed-archive-copy";

    const topline = document.createElement("div");
    topline.className = "feed-archive-topline";

    const mediaBadge = document.createElement("span");
    mediaBadge.className = "feed-archive-badge";
    mediaBadge.textContent = entry.mediaType === "note" ? "Post" : entry.mediaType;

    const categoryBadge = document.createElement("span");
    categoryBadge.className = "feed-archive-badge";
    categoryBadge.textContent = (entry.category || "field-note").replace(/-/g, " ");

    topline.appendChild(mediaBadge);
    topline.appendChild(categoryBadge);

    const title = document.createElement("h4");
    title.className = "feed-archive-title";
    title.textContent = entry.title || "Field Update";

    const meta = document.createElement("p");
    meta.className = "feed-archive-meta";
    meta.textContent = entry.meta || "Published from DeerCamp App";

    const body = document.createElement("p");
    body.className = "feed-archive-body";
    body.textContent = getExcerpt(entry.body || "Published from DeerCamp App.");

    const actions = document.createElement("div");
    actions.className = "feed-archive-actions";

    const openBtn = document.createElement("button");
    openBtn.type = "button";
    openBtn.className = "feed-card-open";
    openBtn.textContent = "Open Post";
    openBtn.addEventListener("click", () => openFeedModal(entry.id, "archive"));

    actions.appendChild(openBtn);

    copy.appendChild(topline);
    copy.appendChild(title);
    copy.appendChild(meta);
    copy.appendChild(body);
    copy.appendChild(actions);

    card.appendChild(media);
    card.appendChild(copy);
    archiveList.appendChild(card);
  });
};
That restores the two rows of 5 behavior by limiting each archive page to 10 cards. The 5-column archive grid itself is already correct. 


