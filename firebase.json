{
  "functions": [
    {
      "codebase": "default",
      "source": "functions",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": [
    {
      "target": "production",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "functions/**",

        "marketing/**",
        "app/**",
        "src/**",
        "components/**",
        "assets/**",
        "android/**",
        "ios/**",

        "images/deercamp_app_splash_screen_design.png",

        "COPY_MAP.txt",
        "README*.txt",
        "*.csv",
        "*.xlsx",
        "*.zip",
        "*.pdf",
        "*.docx",

        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "eas.json",
        "app.json",
        "metro.config.js",
        "babel.config.js",

        "**/*.tsx",
        "**/*.ts",
        "**/*.jks",
        "**/*.pem",
        "google-services.json",
        "**/*.tmp",
        "**/~$*",
        "deercamp-archive-raw/**",
        ".firebase/**",
        "**/*.exe",
        "**/*.dll",
        "**/*.bat",
        "**/*.cmd",
        "**/*.ps1",
        "**/*.sh",
        "**/*.apk",
        "**/*.aab",
        "**/*.keystore",
        "**/*.p12",
        "**/*.pfx",
        "**/*.key",
        "**/*.cer",
        "**/*.crt",
        "**/*.der",
        "**/*.bin"
      ],
      "rewrites": [
        {
          "source": "/r{,/**}",
          "destination": "/r.html"
        },
        {
          "source": "/api/send-steward-welcome",
          "function": "sendStewardWelcome"
        },
        {
          "source": "/api/send-member-welcome",
          "function": "sendStewardWelcome"
        },
        {
          "source": "/api/create-checkout-session",
          "function": "createCheckoutSession"
        },
        {
          "source": "/api/create-billing-portal-session",
          "function": "createBillingPortalSession"
        },
        {
          "source": "/api/stripe-webhook",
          "function": "stripeWebhook"
        }
      ]
    },
    {
      "target": "staging",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "functions/**",

        "marketing/**",
        "app/**",
        "src/**",
        "components/**",
        "assets/**",
        "android/**",
        "ios/**",

        "images/deercamp_app_splash_screen_design.png",

        "COPY_MAP.txt",
        "README*.txt",
        "*.csv",
        "*.xlsx",
        "*.zip",
        "*.pdf",
        "*.docx",

        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "eas.json",
        "app.json",
        "metro.config.js",
        "babel.config.js",

        "**/*.tsx",
        "**/*.ts",
        "**/*.jks",
        "**/*.pem",
        "google-services.json",
        "**/*.tmp",
        "**/~$*",
        "deercamp-archive-raw/**",
        ".firebase/**",
        "**/*.exe",
        "**/*.dll",
        "**/*.bat",
        "**/*.cmd",
        "**/*.ps1",
        "**/*.sh",
        "**/*.apk",
        "**/*.aab",
        "**/*.keystore",
        "**/*.p12",
        "**/*.pfx",
        "**/*.key",
        "**/*.cer",
        "**/*.crt",
        "**/*.der",
        "**/*.bin"
      ],
      "rewrites": [
        {
          "source": "/r{,/**}",
          "destination": "/r.html"
        },
        {
          "source": "/api/send-steward-welcome",
          "function": "sendStewardWelcome"
        },
        {
          "source": "/api/send-member-welcome",
          "function": "sendStewardWelcome"
        },
        {
          "source": "/api/create-checkout-session",
          "function": "createCheckoutSession"
        },
        {
          "source": "/api/create-billing-portal-session",
          "function": "createBillingPortalSession"
        },
        {
          "source": "/api/stripe-webhook",
          "function": "stripeWebhook"
        }
      ]
    }
  ]
}