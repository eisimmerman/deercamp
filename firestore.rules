rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /camps/{campId} {
      allow read, write: if true;
    }

    match /camps/{campId}/campStats/{statId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.campId == campId
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.source == "CampStatsMgr";
      allow update, delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    match /shortLinks/{code} {
      allow read, write: if true;
    }

    match /shortLinkClicks/{clickId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /feedItems/{feedId} {
      allow read: if resource.data.published == true;

      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.published == true;

      allow update, delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }
  }
}
