{
  "expo": {
    "jsEngine": "hermes",
    "android": {
      "jsEngine": "hermes",
      "package": "com.simmerman.deercamp",
      "versionCode": 20,
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./images/App.png",
        "backgroundColor": "#0B0E12"
      }
    },
    "ios": {
      "bundleIdentifier": "com.simmerman.deercamp",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "DeerCamp uses the camera so you can take photos for private field memories shared with your invited camp.",
        "NSMicrophoneUsageDescription": "DeerCamp uses the microphone so you can record audio stories for private field memories shared with your invited camp.",
        "NSPhotoLibraryAddUsageDescription": "DeerCamp saves photos you choose to your field memories and private camp archive.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "7"
    },
    "plugins": [
      "expo-audio",
      "expo-asset",
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBFirestore",
              "RNFBStorage"
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8940ab49-6d61-4523-875d-bdd7fe02152e"
      }
    },
    "scheme": "deercamp",
    "name": "DeerCamp",
    "slug": "deercamp",
    "version": "1.0.0",
    "icon": "./images/App.png"
  }
}
