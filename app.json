{
  "expo": {
    "android": {
      "package": "com.simmerman.deercamp",
      "versionCode": 10,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./images/App.png",
        "backgroundColor": "#0B0E12"
      }
    },
    "plugins": [
      "expo-audio"
    ]
  }
}
